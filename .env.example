# =============================================================================
# AgentOps Platform — Environment Variables
# Copy this file to .env and fill in actual values.
# ⚠️  NEVER commit .env to version control or distribute it (e.g. in packages).
#     If this workspace is shared, rotate AWS, Gemini, LangSmith, webhook, and
#     reload keys immediately.
# =============================================================================

# --- AWS Credentials ---
# On EC2: DO NOT set these — use IAM Instance Role instead.
# Only needed for local development.
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# --- AWS Resource Names ---
S3_BUCKET_NAME=agentops-storage
DYNAMODB_TABLE_VERSIONS=agentops-versions
DYNAMODB_TABLE_EVAL_RUNS=agentops-eval-runs
CLOUDWATCH_NAMESPACE=AgentOps

# --- Gemini API ---
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# --- LangSmith (Observability) ---
# Get your key at: https://smith.langchain.com/settings
# LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agentops

# --- Service Ports ---
TARGET_APP_HOST=0.0.0.0
TARGET_APP_PORT_PROD=9000
TARGET_APP_PORT_STAGING=9001
MCP_STORAGE_PORT=8000
MCP_MONITOR_PORT=8001
MCP_DEPLOY_PORT=8002
ORCHESTRATOR_PORT=7000
DASHBOARD_PORT=3000

# --- MCP Base URLs ---
# Used by server-side clients such as the production dashboard.
MCP_STORAGE_URL=http://localhost:8000
MCP_MONITOR_URL=http://localhost:8001
MCP_DEPLOY_URL=http://localhost:8002

# --- Target-app cost estimation (USD per 1M tokens; update when pricing changes) ---
# GEMINI_INPUT_COST_PER_1M=0.10
# GEMINI_OUTPUT_COST_PER_1M=0.40

# --- Eval runner tuning ---
# EVAL_MAX_RETRIES=3
# EVAL_MAX_CONCURRENT=10
# EVAL_TIMEOUT_SEC=30
# EVAL_CONNECT_SEC=10
# EVAL_BATCH_SIZE=100
# EVAL_JUDGE_MAX_WORKERS=5
# EVAL_JUDGE_BATCH_SIZE=50

# --- Config Paths ---
APP_CONFIG=configs/local.json
PROMPT_TEMPLATE_PATH=configs/prompt_template.json
MODEL_CONFIG_PATH=configs/model_config.json
THRESHOLDS_CONFIG_PATH=configs/thresholds.json

# --- GitHub Webhook ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# --- EC2 Elastic IP ---
# EC2_ELASTIC_IP=x.x.x.x

# --- CORS (comma-separated allowed origins) ---
# In production, restrict to your actual domain(s).
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Config Reload API Key ---
# Protects POST /config/reload from unauthorized access.
# Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
# CONFIG_RELOAD_API_KEY=your_reload_key_here
